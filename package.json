    "url": "https://github.com/elirang/pair-vibe"
  },
  "bugs": {
    "url": "https://github.com/elirang/pair-vibe/issues"
  },
  "homepage": "https://github.com/elirang/pair-vibe#readme",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@inkjs/ui": "^2.0.0",
    "commander": "^13.1.0",
    "ink": "^5.2.1",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
